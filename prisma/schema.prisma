// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id                 String           @default(uuid())
  username           String           @id @unique
  name               String         
  password           String         
  email              String           @unique
  enterprise         Boolean          @default(false)
      
  photo              Image?
  projects           Project[]
  member_in          Member[]
  comments           Comment[]
  sent_invites       ProjectInvite[]  @relation("sent_invites")
  received_invites   ProjectInvite[]  @relation("received_invites")

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Users")
}

model Image {
  id             String      @id @default(uuid())
  filename       String
  url            String
    
  userkey        String      @unique
  user           User        @relation(fields: [userkey], references: [username])

  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@map("Images")
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  due_date    DateTime

  progress    ProjectProgress @default(STARTED)

  ownerkey    String
  owner       User            @relation(fields: [ownerkey], references: [username])

  members     Member[]
  comments    Comment[]
  tasks       Task[]
  events      Event[]
  invites     ProjectInvite[]

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Projects")
}

model Member {
  id String @id @default(uuid())

  role MemberRole @default(MEMBER)

  projectkey String
  project Project @relation(fields: [projectkey], references: [id])

  userkey String
  user User @relation(fields: [userkey], references: [username])

  tasks   Task[]

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Members")
}

model Task {
  id          String        @unique @default(uuid())
  code        String        @id @unique
  name        String
  description String
  due_date    DateTime

  stage       TaskStage     @default(PENDING)
  priority    TaskPriority
  
  projectkey  String
  project     Project       @relation(fields: [projectkey], references: [id])

  ownerkey    String
  owner       Member @relation(fields: [ownerkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Tasks")
}

model Comment {
  id          String    @id @default(uuid())
  content     String
  date     DateTime  @default(now())

  ownerkey    String
  owner       User      @relation(fields: [ownerkey], references: [username])

  projectkey  String
  project     Project   @relation(fields: [projectkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
 
  @@map("Comments")
}

model Event {
  id          String        @unique @default(uuid())
  title       String
  date        DateTime

  projectkey  String
  project     Project       @relation(fields: [projectkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Events")
}

model ProjectInvite {
  id          String      @id @default(uuid())
  pending     Boolean     @default(true)
  accept      Boolean     @default(true)
  
  projectkey  String
  project     Project     @relation(fields: [projectkey], references: [id])
  
  senderkey   String
  sender      User        @relation("sent_invites",fields: [senderkey], references: [username])
  
  receiverkey String
  receiver    User        @relation("received_invites", fields: [receiverkey], references: [username])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("ProjectInvites")
}

enum ProjectProgress {
  STARTED
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
}

enum MemberRole {
  OWNER
  MEMBER
}

enum TaskStage {
  STARTED
  PENDING
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  EXTREME
}