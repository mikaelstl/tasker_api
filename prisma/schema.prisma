// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model Account {
  id                 String           @id @default(uuid())
  password           String         
  email              String           @unique

  role               AccountRole      @default(COMMON)

  user               User?

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Accounts")
}

model User {
  id                 String           @default(uuid())
  username           String           @id @unique
  name               String         
      
  photo              Image?

  accountkey         String           @unique
  account            Account          @relation(fields: [accountkey], references: [id])

  member_in          Member[]
  comments           Comment[]
  notifications      Notification[]

  organization       Organization?    @relation("OrgOwner")

  orgkey             String?
  in_org             Organization?     @relation("OrgMember", fields: [orgkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Users")
}

model Organization {
  id                 String           @id @default(uuid())
  
  name               String
  enterprise         Boolean          @default(false)

  ownerkey           String           @unique
  owner              User             @relation("OrgOwner", fields: [ownerkey], references: [username])

  projects           Project[]
  members            User[]           @relation("OrgMember")

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Organizations")
}

model Image {
  id             String      @id @default(uuid())
  filename       String
  url            String
    
  userkey        String      @unique
  user           User        @relation(fields: [userkey], references: [username])

  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  @@map("Images")
}

model Project {
  id                 String                  @id @default(uuid())
  title              String
  description        String
  due_date           DateTime

  progress           ProjectProgress         @default(STARTED)

  ownerkey           String
  owner              Organization            @relation(fields: [ownerkey], references: [id])

  members            Member[]
  comments           Comment[]
  tasks              Task[]
  events             Event[]

  created_at         DateTime            @default(now())
  updated_at         DateTime            @updatedAt

  @@map("Projects")
}

model Member {
  id String @id @default(uuid())

  role MemberRole @default(MEMBER)

  projectkey String
  project Project @relation(fields: [projectkey], references: [id])

  userkey String
  user User @relation(fields: [userkey], references: [username])

  tasks   Task[]

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Member")
}

model Task {
  id          String        @unique @default(uuid())
  code        String        @id @unique
  name        String
  description String
  due_date    DateTime

  stage       TaskStage     @default(PENDING)
  priority    TaskPriority
  
  projectkey  String
  project     Project       @relation(fields: [projectkey], references: [id])

  ownerkey    String
  owner       Member @relation(fields: [ownerkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Tasks")
}

model Comment {
  id          String    @id @default(uuid())
  content     String
  date     DateTime  @default(now())

  ownerkey    String
  owner       User      @relation(fields: [ownerkey], references: [username])

  projectkey  String
  project     Project   @relation(fields: [projectkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt
 
  @@map("Comments")
}

model Event {
  id          String        @id @unique @default(uuid())
  title       String
  date        DateTime

  projectkey  String
  project     Project       @relation(fields: [projectkey], references: [id])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Events")
}

model Notification {
  id        String      @id @default(uuid())

  action    String

  actorkey  String
  actor     User      @relation(fields: [actorkey], references: [username])

  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@map("Notifications")
}

enum ProjectProgress {
  STARTED
  PENDING
  IN_PROGRESS
  PAUSED
  COMPLETED
  DELAYED
}

enum AccountRole {
  ORGANIZER
  MANAGER
  COMMON
}

enum MemberRole {
  OWNER
  MEMBER
}

enum TaskStage {
  STARTED
  PENDING
  IN_PROGRESS
  REVIEW
  DONE
  DELAYED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  EXTREME
}
